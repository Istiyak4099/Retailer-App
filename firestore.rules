
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY: Allow all access for testing bypass mode.
    // In production, these should be restricted to authenticated users.
    
    match /Users/{userId} {
      allow read, write: if true;
    }

    match /Customers/{customerId} {
      allow read, write: if true;
    }

    match /EmiDetails/{emiId} {
      allow read, write: if true;
    }

    match /Notifications/{notificationId} {
      allow read, write: if true;
    }
    
    // Additional rule for Dealers used in session lookup
    match /Dealers/{dealerId} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
  }
}
